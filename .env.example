APP_NAME=4M Gold AI
SECRET_KEY=change_me_to_a_long_random_value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=4m_gold_ai
MYSQL_USER=root
MYSQL_PASSWORD=your_password
AUTO_CREATE_DATABASE=true

# Railway MySQL also works with MYSQLHOST, MYSQLPORT, MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD.
# You can alternatively set DATABASE_URL or MYSQL_URL to a full mysql+pymysql connection string.

# For production, set this to your Netlify URL, for example:
# FRONTEND_ORIGINS=https://your-site.netlify.app
FRONTEND_ORIGINS=http://localhost:5173
APP_TIMEZONE=Africa/Cairo
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

GOLD_TICKER=GC=F
OIL_TICKER=CL=F
USD_TICKER=DX-Y.NYB
MODEL_PATH=artifacts/gold_model.pkl
AUTO_SYNC_ON_STARTUP=true
AUTO_TRAIN_ON_STARTUP=true
